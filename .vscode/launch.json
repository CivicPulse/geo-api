{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Docker (debugpy)",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "localhost", "port": 5680 },
      "pathMappings": [
        { "localRoot": "${workspaceFolder}/src", "remoteRoot": "/app/src" }
      ],
      "justMyCode": true
    }
  ]
}

{
  "info": {
    "_postman_id": "civpulse-geo-api-collection",
    "name": "CivPulse Geo API",
    "description": "CivPulse Geo API -- geocoding and address validation endpoints using Georgia (GA) addresses. Includes real, fake, and malformed addresses for testing. Run 'POST /geocode' first to populate the address_hash variable used by subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "address_hash",
      "value": "",
      "type": "string"
    },
    {
      "key": "provider_name",
      "value": "census",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check API health status and database connectivity. Returns 200 with status and database fields when healthy, 503 when database is unavailable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Geocoding",
      "item": [
        {
          "name": "Real Addresses",
          "item": [
            {
              "name": "POST /geocode — Macon City Hall",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "if (pm.response.code === 200) {",
                      "    var json = pm.response.json();",
                      "    pm.test('Has address_hash', function () {",
                      "        pm.expect(json.address_hash).to.be.a('string').and.not.empty;",
                      "    });",
                      "    pm.test('Has provider results', function () {",
                      "        pm.expect(json.results.length).to.be.greaterThan(0);",
                      "    });",
                      "    pm.collectionVariables.set('address_hash', json.address_hash);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"address\": \"700 Poplar St, Macon, GA 31201\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/geocode",
                  "host": ["{{baseUrl}}"],
                  "path": ["geocode"]
                },
                "description": "Geocode Macon City Hall. Sets address_hash for subsequent requests."
              },
              "response": []
            },
            {
              "name": "POST /geocode — Mercer University",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "if (pm.response.code === 200) {",
                      "    var json = pm.response.json();",
                      "    pm.test('Has coordinates', function () {",
                      "        var r = json.results[0];",
                      "        pm.expect(r.latitude).to.be.a('number');",
                      "        pm.expect(r.longitude).to.be.a('number');",
                      "    });",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"address\": \"1501 Mercer University Dr, Macon, GA 31207\"\n}"

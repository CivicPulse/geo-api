                      "});",
                      "if (pm.response.code === 200) {",
                      "    var json = pm.response.json();",
                      "    pm.test('Results empty or low confidence', function () {",
                      "        if (json.results.length > 0) {",
                      "            pm.expect(json.results[0].confidence).to.be.below(0.8);",

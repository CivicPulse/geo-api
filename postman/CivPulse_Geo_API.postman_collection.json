        {
          "name": "Address Hash Operations",
          "item": [
            {
              "name": "PUT /geocode/{address_hash}/official",
              "request": {
                "method": "PUT",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"latitude\": 32.8407,\n  \"longitude\": -83.6324,\n  \"reason\": \"Manual override test — Macon City Hall coordinates\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/geocode/{{address_hash}}/official",
                  "host": ["{{baseUrl}}"],
                  "path": ["geocode", "{{address_hash}}", "official"]
                },
                "description": "Set the official geocoding result for the address. Uses Macon City Hall coordinates. Requires address_hash from a prior geocode request."
              },
              "response": []
            },
            {
              "name": "POST /geocode/{address_hash}/refresh",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": ""
                },
                "url": {
                  "raw": "{{baseUrl}}/geocode/{{address_hash}}/refresh",
                  "host": ["{{baseUrl}}"],
                  "path": ["geocode", "{{address_hash}}", "refresh"]
                },
                "description": "Force re-query of all providers for the address, bypassing cache. Requires address_hash from a prior geocode request."
              },
              "response": []
            },
            {
              "name": "GET /geocode/{address_hash}/providers/{provider_name}",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/geocode/{{address_hash}}/providers/{{provider_name}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["geocode", "{{address_hash}}", "providers", "{{provider_name}}"]
                },
                "description": "Fetch the result from a specific provider for an address. The provider_name variable defaults to 'census'."
              },
              "response": []
            }
          ]
        }
